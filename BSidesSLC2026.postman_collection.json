        {
          "name": "Endpoint Agg Search with Detail",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"size\": 0,\n  \"query\": {\n    \"bool\": {\n      \"filter\": [\n        {\n          \"range\": {\n            \"@timestamp\": {\n              \"gte\": \"now-14d\",\n              \"lt\": \"now\",\n              \"time_zone\": \"America/Denver\"\n            }\n          }\n        },\n        {\n          \"range\": {\n            \"rule.level\": {\n              \"gte\": 1,\n              \"lte\": 3\n            }\n          }\n        }\n      ],\n      \"must_not\": [\n        {\n          \"bool\": {\n            \"should\": [\n              { \"exists\": { \"field\": \"data.vulnerability.cve\" } }\n            ]\n          }\n        },\n        {\n          \"wildcard\": {\n            \"rule.description\": {\n              \"value\": \"*CIS Benchmark*\"\n            }\n          }\n        }\n      ]\n    }\n  },\n  \"aggs\": {\n    \"by_endpoint\": {\n      \"terms\": {\n        \"field\": \"agent.name\",\n        \"size\": 50,\n        \"order\": { \"_count\": \"desc\" }\n      },\n      \"aggs\": {\n        \"by_finding_title\": {\n          \"terms\": {\n            \"field\": \"rule.description\",\n            \"size\": 50,\n            \"order\": { \"_count\": \"desc\" }\n          },\n          \"aggs\": {\n            \"by_command\": {\n              \"terms\": {\n                \"field\": \"data.command\",\n                \"size\": 50,\n                \"order\": { \"_count\": \"desc\" }\n              }\n            },\n            \"by_dstuser\": {\n              \"terms\": {\n                \"field\": \"data.dstuser\",\n                \"size\": 50,\n                \"order\": { \"_count\": \"desc\" }\n              }\n            },\n            \"by_package\": {\n              \"terms\": {\n                \"field\": \"data.package\",\n                \"size\": 50,\n                \"order\": { \"_count\": \"desc\" }\n              }\n            }\n          }\n        }\n      }\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl-Indexer}}/wazuh-alerts-4.x-*/_search",
              "host": [
                "{{baseUrl-Indexer}}"
              ],
              "path": [
                "wazuh-alerts-4.x-*",
                "_search"
              ]
            }
